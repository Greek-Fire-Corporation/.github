# Normalize text files to LF in the repository.
* text=auto eol=lf

# Explicit text formats
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Windows command scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.tar binary
*.tar.gz binary
*.mp3 binary
*.mp4 binary
*.mov binary
*.wav binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.sqlite binary
*.sqlite3 binary
